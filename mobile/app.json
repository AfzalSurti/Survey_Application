{
  "expo": {
    "name": "GDRPL Survey",
    "slug": "gdrpl-survey",
    "scheme": "gdrplsurvey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GDRPL Survey to capture structure photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GDRPL Survey to capture survey coordinates."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow GDRPL Survey to attach structure photos from your gallery.",
          "cameraPermission": "Allow GDRPL Survey to open camera apps for structure photos."
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-sqlite",
      "expo-font"
    ],
    "android": {
      "package": "com.gdrpl.survey",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DCEBFB"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.gdrpl.survey"
    },
    "extra": {
      "eas": {
        "projectId": "fdb01712-e63d-42bb-ae83-8a0a070d9305"
      }
    },
    "owner": "afzal635520"
  }
}
